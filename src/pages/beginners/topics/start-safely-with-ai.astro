---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Start safely with AI tools';
const description =
  'A beginner safety baseline for using AI tools without giving away private data, judgment, or responsibility.';

const firstMoves = [
  {
    title: 'Use harmless material first',
    body: 'Start with public, invented, or low-risk text. Do not test a new tool with anything private or important.'
  },
  {
    title: 'Remove private context before pasting',
    body: 'Take out names, account details, secrets, addresses, internal plans, and anything that would create risk if copied elsewhere.'
  },
  {
    title: 'Ask for a draft, not a final answer',
    body: 'Treat the model as a helper that gives you a first pass. You still decide what is accurate, useful, ethical, and worth using.'
  },
  {
    title: 'Check before acting',
    body: 'If the answer affects money, health, legal matters, access, reputation, or another person, slow down and verify with a better source.'
  }
];

const safePrompt = `Explain what AI can help with in everyday work.
Use beginner language.
Include one analogy, three safe uses, and three things I should not paste into an AI tool.`;
---

<BaseLayout title={title} description={description}>
  <section class="card signal-hero" aria-labelledby="safe-ai-title">
    <div class="signal-overlay" aria-hidden="true"></div>
    <div class="signal-grid" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-badge">Beginner article</p>
      <h1 id="safe-ai-title">Start safely with AI tools</h1>
      <p>
        The first AI skill is not prompting. It is knowing what should stay out
        of the tool, what a model can help with, and where the human still has
        to make the final call.
      </p>
      <div class="cta" aria-label="Safe AI beginner actions">
        <a class="primary" href="/beginners/module-0/">Back to Module 0 path</a>
        <a href="/topics/safety-baseline/">Go deeper into the technical guide</a
        >
      </div>
    </div>
  </section>

  <section class="card featured" aria-labelledby="plain-meaning">
    <div class="section-title">
      <div>
        <p class="pill inline">Plain meaning</p>
        <h2 id="plain-meaning">What safety means here</h2>
      </div>
    </div>
    <p>
      AI safety starts with the small habit before the prompt: decide what the
      system should not see. A model can help you think, but it should not
      become the place where private details, secrets, or unchecked decisions
      pile up.
    </p>
  </section>

  <section class="card" aria-labelledby="first-moves">
    <div class="section-title">
      <div>
        <p class="pill inline">First moves</p>
        <h2 id="first-moves">The smallest safe habit</h2>
      </div>
    </div>
    <div class="stacked">
      {
        firstMoves.map((move, index) => (
          <article class="info-panel path-step">
            <strong>
              {index + 1}. {move.title}
            </strong>
            <p>{move.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card" aria-labelledby="safe-prompt">
    <div class="section-title">
      <div>
        <p class="pill inline">Try safely</p>
        <h2 id="safe-prompt">A safe first prompt</h2>
      </div>
    </div>
    <p>Use a prompt that does not include personal or private material:</p>
    <pre><code>{safePrompt}</code></pre>
  </section>

  <section class="card" aria-labelledby="go-deeper">
    <div class="section-title">
      <div>
        <p class="pill inline">Go deeper</p>
        <h2 id="go-deeper">When you want the full safety model</h2>
      </div>
    </div>
    <p>
      The beginner version gives you the habit. The full technical safety guide
      explains the broader baseline for risk, permissions, verification, and
      tool use.
    </p>
    <div class="cta" aria-label="Safe AI deeper links">
      <a class="primary" href="/topics/safety-baseline/">
        Read the full safety guide
      </a>
      <a href="/beginners/topics/running-inference-locally/"
        >Next beginner article</a
      >
    </div>
  </section>
</BaseLayout>
