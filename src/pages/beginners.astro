---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTopicsByModule } from '../data/beginnerTopics';

const title = 'AI for Beginners';
const description =
  'A practical plain-language path through Turtleand AI Lab for people starting from zero while keeping human judgment at the center.';

const modules = getTopicsByModule();

const firstPrinciples = [
  {
    title: 'AI is a tool for thinking and making',
    body: 'It can explain, draft, compare, summarize, classify, code, and call tools when a human gives it direction.'
  },
  {
    title: 'AI is not judgment',
    body: 'A model can sound confident and still be wrong. The human still checks facts, taste, risk, and consequence.'
  },
  {
    title: 'Beginner articles mirror the technical path',
    body: 'Each beginner article is a plain-language counterpart to an existing AI Lab topic, with a safe first move before the deeper guide.'
  }
];

const starterPractices = [
  'Turn one messy non-sensitive note into a clear summary, then correct what the model misunderstood.',
  'Ask for an explanation at your level with a definition, analogy, why it matters, and one caveat.',
  'Compare two options before deciding, then make the final call yourself.',
  'Remove private details, secrets, account data, and internal context before pasting anything.'
];
---

<BaseLayout title={title} description={description}>
  <section class="card signal-hero" aria-labelledby="beginners-title">
    <div class="signal-overlay" aria-hidden="true"></div>
    <div class="signal-grid" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-badge">Beginner doorway</p>
      <h1 id="beginners-title">AI for Beginners</h1>
      <p>
        A practical entrance into Turtleand AI Lab for people starting from
        zero. The goal is to make AI usable, understandable, and human-led from
        the first lesson.
      </p>
      <div class="cta" aria-label="Beginner page actions">
        <a class="primary" href="#beginner-lessons">Browse beginner lessons</a>
        <a href="/modules/module-0/">Open the full AI Lab path</a>
      </div>
    </div>
  </section>

  <section class="card featured" aria-labelledby="page-purpose">
    <div class="section-title">
      <div>
        <p class="pill inline">Purpose</p>
        <h2 id="page-purpose">What this page is for</h2>
      </div>
    </div>
    <p>
      This page is the beginner version of the AI Lab curriculum. It keeps the
      same technical spine where real topic articles exist, but rewrites each
      idea as a smaller plain-language lesson.
    </p>
    <p>
      Module 4 and Module 6 are intentionally not listed here yet because the
      current AI Lab topic files do not contain beginner-mirrorable articles for
      those modules.
    </p>
  </section>

  <section class="card" aria-labelledby="first-principles">
    <div class="section-title">
      <div>
        <p class="pill inline">First principles</p>
        <h2 id="first-principles">Three ideas to keep steady</h2>
      </div>
    </div>
    <ul class="subtopic-list">
      {
        firstPrinciples.map((item) => (
          <li class="subtopic-bullet">
            <span class="bullet-dot" aria-hidden="true" />
            <div>
              <div class="subtopic-title">{item.title}</div>
              <p>{item.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="card" aria-labelledby="starter-practice">
    <div class="section-title">
      <div>
        <p class="pill inline">Start here</p>
        <h2 id="starter-practice">Four practical first moves</h2>
      </div>
    </div>
    <div class="stacked">
      {
        starterPractices.map((practice, index) => (
          <article class="info-panel practice-step">
            <strong>
              {index + 1}. {practice}
            </strong>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="card"
    aria-labelledby="beginner-lessons"
    id="beginner-lessons"
  >
    <div class="section-title">
      <div>
        <p class="pill inline">Beginner lesson spine</p>
        <h2 id="beginner-lessons">The AI Lab path, explained for beginners</h2>
      </div>
    </div>
    <p>
      Choose a module to read the beginner counterparts. Each article links back
      to its full technical topic when you are ready to go deeper.
    </p>
    <div class="stacked">
      {
        modules.map((module) => (
          <a
            class="beginner-module-card clickable-card"
            href={`/beginners/${module.slug}/`}
            aria-label={`Open ${module.label}: ${module.title}`}
          >
            <p class="pill inline">{module.label}</p>
            <h3>{module.title}</h3>
            <p>{module.summary}</p>
            <ul>
              {module.topics.slice(0, 4).map((topic) => (
                <li>{topic.shortTitle}</li>
              ))}
              {module.topics.length > 4 && (
                <li>{module.topics.length - 4} more</li>
              )}
            </ul>
            <span class="card-action" aria-hidden="true">
              Open {module.label} beginner path →
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="card" aria-labelledby="next-step">
    <div class="section-title">
      <div>
        <p class="pill inline">Next step</p>
        <h2 id="next-step">When you are ready to go deeper</h2>
      </div>
    </div>
    <p>
      Start with the beginner article that matches your current task. When the
      idea feels clear enough to use, continue into the matching AI Lab topic
      for the fuller technical version.
    </p>
    <div class="cta" aria-label="Next beginner actions">
      <a class="primary" href="/beginners/module-0/"
        >Open Module 0 beginner path</a
      >
      <a href="https://atlas.turtleand.com/">Compare tools in AI Atlas</a>
    </div>
  </section>
</BaseLayout>
