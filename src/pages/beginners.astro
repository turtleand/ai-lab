---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'AI for Beginners';
const description =
  'A practical plain-language path through Turtleand AI Lab for people starting from zero while keeping human judgment at the center.';

const firstPrinciples = [
  {
    title: 'AI is a tool for thinking and making',
    body: 'It can explain, draft, compare, summarize, classify, code, and call tools when a human gives it direction.'
  },
  {
    title: 'AI is not judgment',
    body: 'A model can sound confident and still be wrong. The human still checks facts, taste, risk, and consequence.'
  },
  {
    title: 'AI Lab is the deeper path',
    body: 'The main AI Lab has the full technical structure. This beginner path explains the same ideas in smaller, practical lessons.'
  }
];

const humanRoles = [
  'Set the goal before asking the system to help.',
  'Give context, constraints, examples, and standards.',
  'Check the output against reality before trusting it.',
  'Decide what is ethical, useful, tasteful, and worth doing.',
  'Turn useful learning into a repeatable habit or public artifact.'
];

const starterPractices = [
  {
    label: '1',
    title: 'Turn one messy note into a clear summary',
    body: 'Paste non-sensitive notes, ask for a five-bullet summary, then correct anything the model misunderstood.'
  },
  {
    label: '2',
    title: 'Ask for an explanation at your level',
    body: 'Use a prompt like: Explain this for a beginner. Include a definition, analogy, why it matters, and one caveat.'
  },
  {
    label: '3',
    title: 'Compare two options before deciding',
    body: 'Ask for trade-offs, risks, and a recommendation. Then make the final call yourself.'
  },
  {
    label: '4',
    title: 'Create a safe habit',
    body: 'Before pasting anything, remove private details, secrets, account data, and internal operational context.'
  }
];

const beginnerModules = [
  {
    module: 'Module 0',
    title: 'Start safely',
    mainHref: '/modules/module-0/',
    beginnerHref: '/beginners/topics/running-inference-locally/',
    beginnerLabel: 'Start with local AI basics',
    body: 'The beginner version of setup, safety, model basics, and the first useful workflows.',
    lessons: [
      'What AI can help with today, in plain language.',
      'How running a model locally differs from using a hosted chat app.',
      'What not to paste into an AI tool, and why.'
    ],
    practice:
      'Read the local AI beginner article, try one safe prompt, then mark what was useful, wrong, or risky.'
  },
  {
    module: 'Module 1',
    title: 'Use AI for everyday work',
    mainHref: '/modules/module-1/',
    body: 'Plain-language counterparts to prompting, tool choice, voice, multimodal work, and collaboration habits.',
    lessons: [
      'Summarize, rewrite, compare, and plan without giving away judgment.',
      'Choose between chat, search, voice, image, and coding tools.',
      'Work with AI as a collaborator, not an authority.'
    ],
    practice:
      'Take one real workflow and split it into goal, context, draft, review, and final decision.'
  },
  {
    module: 'Module 2',
    title: 'Build a personal AI operating rhythm',
    mainHref: '/modules/module-2/',
    body: 'A beginner bridge into automation, memory, distribution, and repeatable knowledge workflows.',
    lessons: [
      'Turn repeated tasks into checklists before automating them.',
      'Understand the difference between notes, memory, and public artifacts.',
      'Use AI to prepare work without letting it publish for you.'
    ],
    practice:
      'Choose one repeated weekly task and write the human approval step before any automation step.'
  },
  {
    module: 'Module 3',
    title: 'Understand the ideas under the hood',
    mainHref: '/modules/module-3/',
    body: 'Beginner explanations for interfaces, inputs, outputs, context, planning, and reasoning patterns.',
    lessons: [
      'Why models predict useful text but do not know truth by default.',
      'Why context is not the same thing as memory.',
      'How breaking a task into steps improves the answer.'
    ],
    practice:
      'Ask the same question twice: once vague, once with goal, context, constraints, and format. Compare the outputs.'
  },
  {
    module: 'Module 4',
    title: 'Find and use your knowledge',
    mainHref: '/modules/module-4/',
    body: 'A non-technical path into retrieval, document search, chunking, and checking whether answers are grounded.',
    lessons: [
      'Why AI needs the right source material before answering about your documents.',
      'How search, summaries, and citations reduce guessing.',
      'What to verify before trusting a generated answer.'
    ],
    practice:
      'Give AI a short public article and ask it to answer only from that text. Check if every claim is supported.'
  },
  {
    module: 'Module 5',
    title: 'Understand agents without the hype',
    mainHref: '/modules/module-5/',
    body: 'Beginner versions of agent loops, tool use, control flow, human agency, and reliability.',
    lessons: [
      'What makes an agent different from a normal chat.',
      'Why smart outputs are not the same as reliable systems.',
      'Where human approval belongs in an agent workflow.'
    ],
    practice:
      'Sketch a simple agent loop: goal, context, tool call, result check, human decision.'
  },
  {
    module: 'Module 6',
    title: 'Move from experiments to products',
    mainHref: '/modules/module-6/',
    body: 'A beginner bridge into local models, deployment, evaluation, and shipping useful AI systems.',
    lessons: [
      'Why a demo is not the same thing as a dependable product.',
      'How to test outputs before trusting a workflow.',
      'What changes when other people depend on the system.'
    ],
    practice:
      'Write three checks a workflow must pass before another person should use it.'
  }
];
---

<BaseLayout title={title} description={description}>
  <section class="card signal-hero" aria-labelledby="beginners-title">
    <div class="signal-overlay" aria-hidden="true"></div>
    <div class="signal-grid" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-badge">Beginner doorway</p>
      <h1 id="beginners-title">AI for Beginners</h1>
      <p>
        A practical entrance into Turtleand AI Lab for people starting from
        zero. The goal is to make AI usable, understandable, and human-led from
        the first lesson.
      </p>
      <div class="cta" aria-label="Beginner page actions">
        <a class="primary" href="#beginner-lessons">Browse beginner lessons</a>
        <a href="/modules/module-0/">Open the full AI Lab path</a>
      </div>
    </div>
  </section>

  <section class="card featured" aria-labelledby="page-purpose">
    <div class="section-title">
      <div>
        <p class="pill inline">Purpose</p>
        <h2 id="page-purpose">What this page is for</h2>
      </div>
    </div>
    <p>
      This page is not a separate philosophy page. It is the beginner version of
      the AI Lab curriculum: the same module hierarchy where it makes sense,
      rewritten as smaller lessons for people who do not yet have the technical
      vocabulary.
    </p>
    <p>
      Each beginner article should sit beside a main AI Lab idea. The beginner
      version explains the idea, shows a small safe use case, and gives a simple
      practice step before sending the reader deeper into the full module.
    </p>
  </section>

  <section class="card" aria-labelledby="plain-definition">
    <div class="section-title">
      <div>
        <p class="pill inline">Plain definition</p>
        <h2 id="plain-definition">What AI means here</h2>
      </div>
    </div>
    <p>
      AI is software that can recognize patterns, generate useful outputs, and
      help with thinking or action when a human gives it direction.
    </p>
    <p>
      That can mean chat, search help, writing support, image generation, coding
      assistance, audio tools, research workflows, or agents that use tools. The
      names change. The human responsibility does not.
    </p>
  </section>

  <section class="card" aria-labelledby="first-principles">
    <div class="section-title">
      <div>
        <p class="pill inline">First principles</p>
        <h2 id="first-principles">Three ideas to keep steady</h2>
      </div>
    </div>
    <ul class="subtopic-list">
      {
        firstPrinciples.map((item) => (
          <li class="subtopic-bullet">
            <span class="bullet-dot" aria-hidden="true" />
            <div>
              <div class="subtopic-title">{item.title}</div>
              <p>{item.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="card" aria-labelledby="human-center">
    <div class="section-title">
      <div>
        <p class="pill inline">Human center</p>
        <h2 id="human-center">What the human keeps doing</h2>
      </div>
    </div>
    <p>
      Turtleand treats AI as a force multiplier, not a replacement for agency. A
      useful system makes the human more capable, not less responsible.
    </p>
    <ul>
      {humanRoles.map((role) => <li>{role}</li>)}
    </ul>
  </section>

  <section class="card" aria-labelledby="starter-practice">
    <div class="section-title">
      <div>
        <p class="pill inline">Start here</p>
        <h2 id="starter-practice">Four practical first moves</h2>
      </div>
    </div>
    <div class="stacked">
      {
        starterPractices.map((step) => (
          <article class="log-entry">
            <strong>
              {step.label}. {step.title}
            </strong>
            <p>{step.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="card"
    aria-labelledby="beginner-lessons"
    id="beginner-lessons"
  >
    <div class="section-title">
      <div>
        <p class="pill inline">Beginner lesson spine</p>
        <h2 id="beginner-lessons">The AI Lab path, explained for beginners</h2>
      </div>
    </div>
    <p>
      These are the beginner article lanes for AI Lab. They follow the main
      module order as closely as useful, but each lane starts with plain
      language, a practical use case, and a safety habit before going deeper.
    </p>
    <div class="stacked">
      {
        beginnerModules.map((module) => (
          <article class="log-entry">
            <p class="pill inline">{module.module}</p>
            <h3>{module.title}</h3>
            <p>{module.body}</p>
            <ul>
              {module.lessons.map((lesson) => (
                <li>{lesson}</li>
              ))}
            </ul>
            <p>
              <strong>Practice:</strong> {module.practice}
            </p>
            {module.beginnerHref && (
              <p>
                <a href={module.beginnerHref}>{module.beginnerLabel} →</a>
              </p>
            )}
            <p>
              <a href={module.mainHref}>Open the full {module.module} →</a>
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="card" aria-labelledby="next-step">
    <div class="section-title">
      <div>
        <p class="pill inline">Next step</p>
        <h2 id="next-step">When you are ready to go deeper</h2>
      </div>
    </div>
    <p>
      Start with the beginner practice that matches your current task. When the
      idea feels clear enough to use, continue into the matching AI Lab module
      for the fuller technical version.
    </p>
    <div class="cta" aria-label="Next beginner actions">
      <a class="primary" href="/modules/module-0/">Open Module 0</a>
      <a href="https://atlas.turtleand.com/">Compare tools in AI Atlas</a>
    </div>
  </section>
</BaseLayout>
