---
// Portal Trio - quiet ecosystem route cards
---

<section class="portal-trio" aria-label="Featured Resources">
  <a
    href="https://hermes.turtleand.com/"
    class="portal-card portal-hermes"
    target="_blank"
    rel="noopener"
  >
    <div class="portal-content">
      <div class="portal-icon">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect
            x="8"
            y="12"
            width="32"
            height="24"
            rx="2"
            stroke="currentColor"
            stroke-width="2"></rect>
          <path
            d="M14 22l4 4-4 4M22 30h8"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
          <circle cx="24" cy="8" r="2" fill="currentColor"></circle>
        </svg>
      </div>
      <h3 class="portal-title">Hermes</h3>
      <p class="portal-desc">
        Voice-first agent operations, scheduling, tools, skills, and reliable
        human-AI workflows.
      </p>
      <span class="portal-cta">
        Enter <span class="cta-arrow">→</span>
      </span>
    </div>
  </a>

  <a
    href="https://atlas.turtleand.com/"
    class="portal-card portal-atlas"
    target="_blank"
    rel="noopener"
  >
    <div class="portal-content">
      <div class="portal-icon">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="2"
          ></circle>
          <path
            d="M24 8v32M8 24h32"
            stroke="currentColor"
            stroke-width="1.5"
            opacity="0.5"></path>
          <path d="M24 18l4 6-4 6-4-6 4-6z" fill="currentColor"></path>
          <circle cx="24" cy="24" r="3" stroke="currentColor" stroke-width="2"
          ></circle>
        </svg>
      </div>
      <h3 class="portal-title">AI Atlas</h3>
      <p class="portal-desc">
        Interactive map of AI tools I've charted on my journey.
      </p>
      <span class="portal-cta">
        Explore <span class="cta-arrow">→</span>
      </span>
    </div>
  </a>

  <a
    href="https://handbook.turtleand.com/"
    class="portal-card portal-handbook"
    target="_blank"
    rel="noopener"
  >
    <div class="portal-content">
      <div class="portal-icon">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M12 8h20c2 0 4 2 4 4v24c0 2-2 4-4 4H12V8z"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin="round"></path>
          <path d="M12 8v32" stroke="currentColor" stroke-width="2"></path>
          <path
            d="M18 18h12M18 24h12M18 30h8"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
          <circle cx="38" cy="14" r="2" fill="currentColor"></circle>
        </svg>
      </div>
      <h3 class="portal-title">Handbook</h3>
      <p class="portal-desc">
        Human-AI collaboration principles. Quick reference for teams and
        individuals.
      </p>
      <span class="portal-cta">
        Enter <span class="cta-arrow">→</span>
      </span>
    </div>
  </a>
</section>

<style>
  .portal-trio {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 1rem 0 1.5rem;
  }

  .portal-card {
    --portal-accent: var(--accent);
    position: relative;
    display: flex;
    min-height: 210px;
    padding: 1.35rem;
    overflow: hidden;
    color: var(--ink);
    text-decoration: none;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--portal-accent) 8%, transparent),
        transparent 42%
      ),
      var(--panel);
    border: 1px solid
      color-mix(in srgb, var(--portal-accent) 22%, var(--border) 78%);
    border-radius: 1rem;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.07);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .portal-hermes {
    --portal-accent: #4f9dff;
  }

  .portal-atlas {
    --portal-accent: #c59035;
  }

  .portal-handbook {
    --portal-accent: #2fbf8f;
  }

  .portal-content {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 100%;
  }

  .portal-icon {
    width: 44px;
    height: 44px;
    margin-bottom: 0.9rem;
    color: var(--portal-accent);
  }

  .portal-icon svg {
    width: 100%;
    height: 100%;
  }

  .portal-title {
    margin: 0 0 0.65rem;
    color: var(--portal-accent);
    font-size: 1.45rem;
    font-weight: 750;
    letter-spacing: 0.01em;
  }

  .portal-desc {
    flex: 1;
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .portal-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.5rem;
    min-height: 2.35rem;
    margin-top: 1.35rem;
    padding: 0.55rem 1rem;
    border: 1px solid
      color-mix(in srgb, var(--portal-accent) 28%, var(--border) 72%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--portal-accent) 10%, transparent);
    color: var(--portal-accent);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-arrow {
    transition: transform 0.2s ease;
  }

  .portal-card:hover,
  .portal-card:focus-visible {
    border-color: color-mix(
      in srgb,
      var(--portal-accent) 42%,
      var(--border) 58%
    );
    box-shadow: 0 18px 42px rgba(31, 162, 255, 0.12);
    transform: translateY(-3px);
  }

  .portal-card:hover .cta-arrow,
  .portal-card:focus-visible .cta-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 1024px) {
    .portal-trio {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .portal-trio {
      grid-template-columns: 1fr;
    }
  }
</style>
